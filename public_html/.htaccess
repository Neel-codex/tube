# TradeVision Pro - root .htaccess
Options -Indexes
ServerSignature Off
DirectoryIndex index.php index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  # Force HTTPS (uncomment on production with SSL)
  # RewriteCond %{HTTPS} off
  # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Pass Authorization header to PHP for JWT
  RewriteCond %{HTTP:Authorization} ^(.*)
  RewriteRule .* - [E=HTTP_AUTHORIZATION:%1]
</IfModule>

# Protect sensitive files & directories
<FilesMatch "(^\.|composer\.(json|lock)|\.md$|\.sql$|\.log$)">
  Require all denied
</FilesMatch>

# Block access to config, includes, storage, cron source from the web
RedirectMatch 403 ^/(config|includes|storage)(/.*)?$

# Security headers (mod_headers)
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/jpeg "access plus 30 days"
</IfModule>

# Gzip
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json text/plain
</IfModule>
