# Serve uploaded files but NEVER execute scripts in this directory
Options -Indexes -ExecCGI
RemoveHandler .php .phtml .php3 .php4 .php5 .php7 .php8 .pl .py .cgi .asp .sh
RemoveType .php .phtml .php3 .php4 .php5 .php7 .php8

<FilesMatch "\.(php|phtml|php3|php4|php5|php7|php8|pl|py|cgi|asp|sh|exe)$">
  Require all denied
</FilesMatch>

# Force download / inline image only for known image types
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
</IfModule>
